<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Flippo.App.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
             x:Class="Flippo.App.Views.SetDetailView"
             x:DataType="vm:SetDetailViewModel">

    <Grid RowDefinitions="Auto,*" Margin="24">
        <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,16">
            <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
                <TextBlock Text="{Binding Title}" FontSize="26" FontWeight="SemiBold"/>
                <TextBlock FontSize="12" Opacity="0.6">
                    <Run Text="{Binding Entries.Count}"/><Run Text=" Karten"/>
                </TextBlock>
            </StackPanel>
            <TextBox Grid.Column="1" Width="240" PlaceholderText="Suchen…"
                     Text="{Binding SearchText}" VerticalAlignment="Center"/>
        </Grid>

        <DataGrid Grid.Row="1" ItemsSource="{Binding Entries}" IsReadOnly="True"
                  GridLinesVisibility="Horizontal"
                  CanUserResizeColumns="True" CanUserSortColumns="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Quelle" Binding="{Binding SourceText}" Width="*"/>
                <DataGridTextColumn Header="Ziel" Binding="{Binding TargetText}" Width="*"/>
                <DataGridTextColumn Header="Fach" Binding="{Binding BoxLevel}" Width="60"/>
                <DataGridTextColumn Header="fällig am" Binding="{Binding DueDisplay}" Width="110"/>
                <DataGridCheckBoxColumn Header="Leech" Binding="{Binding IsLeech}" Width="70"/>
                <DataGridTextColumn Header="Tags" Binding="{Binding TagsDisplay}" Width="180"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
