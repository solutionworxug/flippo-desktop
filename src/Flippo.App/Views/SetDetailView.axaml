<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Flippo.App.ViewModels"
             xmlns:loc="using:Flippo.App.Localization"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="600"
             x:Class="Flippo.App.Views.SetDetailView"
             x:DataType="vm:SetDetailViewModel"
             Focusable="True">

    <UserControl.Resources>
        <!-- DataGrid-Theme-Tokens lokal auf Brush.* umgelenkt (Fluent-DataGrid-Keys, siehe Avalonia.Controls.DataGrid/Themes/Fluent.xaml).
             Brush.Accent.Soft ist bereits eine teiltransparente Fläche, daher die Selection-Opacity-Keys auf 1 gesetzt
             (sonst würde die Fluent-Default-Opacity zusätzlich abdunkeln/aufhellen). -->
        <SolidColorBrush x:Key="DataGridColumnHeaderForegroundBrush" Color="{DynamicResource Color.Text.Secondary}"/>
        <SolidColorBrush x:Key="DataGridColumnHeaderBackgroundBrush" Color="{DynamicResource Color.Surface.Subtle}"/>
        <SolidColorBrush x:Key="DataGridColumnHeaderHoveredBackgroundBrush" Color="{DynamicResource Color.Surface.Subtle}"/>
        <SolidColorBrush x:Key="DataGridColumnHeaderPressedBackgroundBrush" Color="{DynamicResource Color.Surface.Subtle}"/>
        <SolidColorBrush x:Key="DataGridRowHoveredBackgroundColor" Color="{DynamicResource Color.Surface.Subtle}"/>
        <SolidColorBrush x:Key="DataGridRowSelectedBackgroundBrush" Color="{DynamicResource Color.Accent.Soft}"/>
        <SolidColorBrush x:Key="DataGridRowSelectedHoveredBackgroundBrush" Color="{DynamicResource Color.Accent.Soft}"/>
        <SolidColorBrush x:Key="DataGridRowSelectedUnfocusedBackgroundBrush" Color="{DynamicResource Color.Accent.Soft}"/>
        <SolidColorBrush x:Key="DataGridRowSelectedHoveredUnfocusedBackgroundBrush" Color="{DynamicResource Color.Accent.Soft}"/>
        <x:Double x:Key="DataGridRowSelectedBackgroundOpacity">1</x:Double>
        <x:Double x:Key="DataGridRowSelectedHoveredBackgroundOpacity">1</x:Double>
        <x:Double x:Key="DataGridRowSelectedUnfocusedBackgroundOpacity">1</x:Double>
        <x:Double x:Key="DataGridRowSelectedHoveredUnfocusedBackgroundOpacity">1</x:Double>
        <SolidColorBrush x:Key="DataGridGridLinesBrush" Color="{DynamicResource Color.Border.Subtle}"/>
        <SolidColorBrush x:Key="DataGridCellFocusVisualPrimaryBrush" Color="{DynamicResource Color.Accent}"/>
    </UserControl.Resources>

    <UserControl.KeyBindings>
        <KeyBinding Gesture="Ctrl+N" Command="{Binding NewCardCommand}"/>
        <KeyBinding Gesture="F2" Command="{Binding EditSelectedCommand}"/>
        <KeyBinding Gesture="Ctrl+Enter" Command="{Binding SaveAndNextCommand}"/>
        <KeyBinding Gesture="Ctrl+S" Command="{Binding SaveAndCloseCommand}"/>
        <KeyBinding Gesture="Escape" Command="{Binding CancelEditCommand}"/>
    </UserControl.KeyBindings>

    <Grid RowDefinitions="Auto,*" Margin="24">
        <!-- Kopf -->
        <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,16">
            <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
                <TextBlock Classes="page-title" Text="{Binding Title}"/>
                <TextBlock Classes="caption">
                    <Run Text="{Binding Entries.Count}"/><Run Text="{loc:T Detail_CardsSuffix}"/>
                </TextBlock>
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <SplitButton Content="{loc:T Detail_Learn}" Command="{Binding LearnCommand}" CommandParameter="Due"
                             ToolTip.Tip="{loc:T Detail_LearnTooltip}">
                    <SplitButton.Flyout>
                        <MenuFlyout>
                            <MenuItem Header="{loc:T Detail_Due}"     Command="{Binding LearnCommand}" CommandParameter="Due"/>
                            <MenuItem Header="{loc:T Detail_All}"     Command="{Binding LearnCommand}" CommandParameter="All"/>
                            <MenuItem Header="{loc:T Detail_New}"     Command="{Binding LearnCommand}" CommandParameter="New"/>
                            <MenuItem Header="{loc:T Detail_Leeches}" Command="{Binding LearnCommand}" CommandParameter="Leech"/>
                        </MenuFlyout>
                    </SplitButton.Flyout>
                </SplitButton>
                <TextBox Width="200" PlaceholderText="{loc:T Detail_SearchPlaceholder}" Text="{Binding SearchText}"/>
                <Button Content="{loc:T Detail_NewCard}" Command="{Binding NewCardCommand}" Classes="accent"
                        ToolTip.Tip="{loc:T Detail_NewCardTooltip}"/>
                <Button ToolTip.Tip="{loc:T Detail_SetActions}">
                    <PathIcon Classes="icon" Data="{DynamicResource Icon.more}"/>
                    <Button.Flyout>
                        <MenuFlyout>
                            <MenuItem Header="{loc:T Detail_EditSet}" Command="{Binding EditSetCommand}"/>
                            <MenuItem Header="{loc:T Detail_DeleteSet}" Command="{Binding DeleteSetCommand}"/>
                        </MenuFlyout>
                    </Button.Flyout>
                </Button>
            </StackPanel>
        </Grid>

        <!-- Body: DataGrid + Editor-Panel -->
        <Grid Grid.Row="1" ColumnDefinitions="*,Auto">
            <Border Grid.Column="0" CornerRadius="{DynamicResource Radius.Card}" ClipToBounds="True"
                    Background="{DynamicResource Brush.Surface.Card}" BoxShadow="{DynamicResource Shadow.Card}">
                <DataGrid x:Name="EntryGrid"
                          ItemsSource="{Binding Entries}"
                          SelectedItem="{Binding SelectedRow}"
                          IsReadOnly="True" GridLinesVisibility="Horizontal"
                          CanUserResizeColumns="True" CanUserSortColumns="True"
                          RowHeight="40" ColumnHeaderHeight="40"
                          Background="{DynamicResource Brush.Surface.Card}"
                          Foreground="{DynamicResource Brush.Text.Primary}"
                          RowBackground="Transparent"
                          KeyDown="OnGridKeyDown" DoubleTapped="OnRowDoubleTapped">
                    <DataGrid.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="{loc:T Ctx_Edit}" Command="{Binding EditSelectedCommand}"/>
                            <Separator/>
                            <MenuItem Header="{loc:T Ctx_Delete}" Command="{Binding DeleteSelectedCommand}"/>
                        </ContextMenu>
                    </DataGrid.ContextMenu>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="{loc:T Detail_ColSource}" Binding="{Binding SourceText}" Width="*"/>
                        <DataGridTextColumn Header="{loc:T Detail_ColTarget}" Binding="{Binding TargetText}" Width="*"/>
                        <DataGridTextColumn Header="{loc:T Detail_ColBox}" Binding="{Binding BoxLevel}" Width="55"/>
                        <DataGridTextColumn Header="{loc:T Detail_ColDue}" Binding="{Binding DueDisplay}" Width="105"/>
                        <DataGridCheckBoxColumn Header="{loc:T Detail_ColLeech}" Binding="{Binding IsLeech}" Width="65"/>
                        <DataGridTextColumn Header="{loc:T Detail_ColTags}" Binding="{Binding TagsDisplay}" Width="160"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <!-- Andock-Panel rechts (kein Modal) -->
            <Border Grid.Column="1" IsVisible="{Binding IsEditorOpen}"
                    Width="360" Margin="16,0,0,0" Padding="16"
                    Background="{DynamicResource Brush.Surface.Subtle}" CornerRadius="{DynamicResource Radius.Card}">
                <ScrollViewer>
                    <StackPanel Spacing="10" DataContext="{Binding Editor}" x:DataType="vm:CardEditorViewModel">
                        <TextBlock Classes="section" Text="{Binding HeaderText}"/>

                        <StackPanel Spacing="3">
                            <TextBlock Text="{loc:T Detail_FieldSource}" Classes="caption"/>
                            <TextBox x:Name="SourceBox" Text="{Binding SourceText}" TabIndex="0"/>
                        </StackPanel>
                        <StackPanel Spacing="3">
                            <TextBlock Text="{loc:T Detail_FieldTarget}" Classes="caption"/>
                            <TextBox Text="{Binding TargetText}" TabIndex="1"/>
                        </StackPanel>
                        <StackPanel Spacing="3">
                            <TextBlock Text="{loc:T Detail_FieldAcceptedAnswers}" Classes="caption"/>
                            <TextBox Text="{Binding AcceptedAnswers}" TabIndex="2"/>
                        </StackPanel>
                        <StackPanel Spacing="3">
                            <TextBlock Text="{loc:T Detail_FieldExampleSentence}" Classes="caption"/>
                            <TextBox Text="{Binding ExampleSentence}" TabIndex="3"/>
                        </StackPanel>
                        <StackPanel Spacing="3">
                            <TextBlock Text="{loc:T Detail_FieldNotes}" Classes="caption"/>
                            <TextBox Text="{Binding Notes}" TabIndex="4"/>
                        </StackPanel>

                        <Expander Header="{loc:T Detail_More}">
                            <StackPanel Spacing="10" Margin="0,8,0,0">
                                <StackPanel Spacing="3">
                                    <TextBlock Text="{loc:T Detail_FieldPartOfSpeech}" Classes="caption"/>
                                    <TextBox Text="{Binding PartOfSpeech}"/>
                                </StackPanel>
                                <StackPanel Spacing="3">
                                    <TextBlock Text="{loc:T Detail_FieldGender}" Classes="caption"/>
                                    <TextBox Text="{Binding Gender}"/>
                                </StackPanel>
                                <StackPanel Spacing="3">
                                    <TextBlock Text="{loc:T Detail_FieldPluralForm}" Classes="caption"/>
                                    <TextBox Text="{Binding PluralForm}"/>
                                </StackPanel>
                                <StackPanel Spacing="3">
                                    <TextBlock Text="{loc:T Detail_FieldVerbForms}" Classes="caption"/>
                                    <TextBox Text="{Binding VerbForms}"/>
                                </StackPanel>
                                <StackPanel Spacing="3">
                                    <TextBlock Text="{loc:T Detail_FieldPronunciation}" Classes="caption"/>
                                    <TextBox Text="{Binding Pronunciation}"/>
                                </StackPanel>
                                <StackPanel Spacing="3">
                                    <TextBlock Text="{loc:T Detail_FieldTags}" Classes="caption"/>
                                    <TextBox Text="{Binding Tags}"/>
                                </StackPanel>
                                <StackPanel Spacing="3">
                                    <TextBlock Text="{loc:T Detail_FieldMnemonic}" Classes="caption"/>
                                    <TextBox Text="{Binding Mnemonic}"/>
                                </StackPanel>
                            </StackPanel>
                        </Expander>

                        <StackPanel Spacing="6" Margin="0,6,0,0"
                                    DataContext="{Binding $parent[UserControl].DataContext}"
                                    x:DataType="vm:SetDetailViewModel">
                            <Button Content="{loc:T Detail_SaveAndNext}" Command="{Binding SaveAndNextCommand}"
                                    HorizontalAlignment="Stretch" Classes="accent" ToolTip.Tip="{loc:T Detail_SaveAndNextTooltip}"/>
                            <Grid ColumnDefinitions="*,6,*">
                                <Button Grid.Column="0" Content="{loc:T Detail_Save}" Command="{Binding SaveAndCloseCommand}"
                                        HorizontalAlignment="Stretch" ToolTip.Tip="{loc:T Detail_SaveTooltip}"/>
                                <Button Grid.Column="2" Content="{loc:T Detail_Cancel}" Command="{Binding CancelEditCommand}"
                                        HorizontalAlignment="Stretch" ToolTip.Tip="{loc:T Detail_CancelTooltip}"/>
                            </Grid>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</UserControl>
