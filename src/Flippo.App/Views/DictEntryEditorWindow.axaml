<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Flippo.App.ViewModels"
        xmlns:loc="using:Flippo.App.Localization"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        x:Class="Flippo.App.Views.DictEntryEditorWindow"
        x:DataType="vm:DictEntryEditorViewModel"
        Title="{loc:T DictEntry_HeaderNew}"
        Width="440" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        CanResize="False">
    <StackPanel Margin="24" Spacing="12">
        <TextBlock Text="{Binding HeaderText}" FontSize="20" FontWeight="SemiBold"/>

        <Grid ColumnDefinitions="*,12,*">
            <StackPanel Grid.Column="0" Spacing="4">
                <TextBlock Text="{loc:T Dict_ColSource}" FontSize="12" Opacity="0.7"/>
                <TextBox Text="{Binding SourceWord}"/>
            </StackPanel>
            <StackPanel Grid.Column="2" Spacing="4">
                <TextBlock Text="{loc:T Dict_ColTarget}" FontSize="12" Opacity="0.7"/>
                <TextBox Text="{Binding TargetWord}"/>
            </StackPanel>
        </Grid>
        <Grid ColumnDefinitions="*,12,*">
            <StackPanel Grid.Column="0" Spacing="4">
                <TextBlock Text="{loc:T Dict_ColPos}" FontSize="12" Opacity="0.7"/>
                <TextBox Text="{Binding PartOfSpeech}"/>
            </StackPanel>
            <StackPanel Grid.Column="2" Spacing="4">
                <TextBlock Text="{loc:T Detail_FieldGender}" FontSize="12" Opacity="0.7"/>
                <TextBox Text="{Binding Gender}"/>
            </StackPanel>
        </Grid>
        <StackPanel Spacing="4">
            <TextBlock Text="{loc:T Dict_ColExample}" FontSize="12" Opacity="0.7"/>
            <TextBox Text="{Binding ExampleSentence}"/>
        </StackPanel>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8" Margin="0,8,0,0">
            <Button Content="{loc:T SetEditor_Cancel}" Click="OnCancel" MinWidth="90"/>
            <Button Content="{loc:T SetEditor_Save}" Click="OnSave" MinWidth="90" Classes="accent"
                    IsEnabled="{Binding CanSave}"/>
        </StackPanel>
    </StackPanel>
</Window>
