<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Flippo.App.ViewModels"
        xmlns:loc="using:Flippo.App.Localization"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        x:Class="Flippo.App.Views.DictEntryEditorWindow"
        x:DataType="vm:DictEntryEditorViewModel"
        Title="{loc:T DictEntry_HeaderNew}"
        Width="440" SizeToContent="Height"
        Background="{DynamicResource Brush.Bg.App}"
        WindowStartupLocation="CenterOwner"
        CanResize="False">
    <Border Classes="app-card" Margin="16">
        <StackPanel Spacing="12">
            <TextBlock Classes="section" Text="{Binding HeaderText}"/>

            <Grid ColumnDefinitions="*,12,*">
                <StackPanel Grid.Column="0" Spacing="4">
                    <TextBlock Classes="caption" Text="{loc:T Dict_ColSource}"/>
                    <TextBox Text="{Binding SourceWord}" CornerRadius="{DynamicResource Radius.Control}"/>
                </StackPanel>
                <StackPanel Grid.Column="2" Spacing="4">
                    <TextBlock Classes="caption" Text="{loc:T Dict_ColTarget}"/>
                    <TextBox Text="{Binding TargetWord}" CornerRadius="{DynamicResource Radius.Control}"/>
                </StackPanel>
            </Grid>
            <Grid ColumnDefinitions="*,12,*">
                <StackPanel Grid.Column="0" Spacing="4">
                    <TextBlock Classes="caption" Text="{loc:T Dict_ColPos}"/>
                    <TextBox Text="{Binding PartOfSpeech}" CornerRadius="{DynamicResource Radius.Control}"/>
                </StackPanel>
                <StackPanel Grid.Column="2" Spacing="4">
                    <TextBlock Classes="caption" Text="{loc:T Detail_FieldGender}"/>
                    <TextBox Text="{Binding Gender}" CornerRadius="{DynamicResource Radius.Control}"/>
                </StackPanel>
            </Grid>
            <StackPanel Spacing="4">
                <TextBlock Classes="caption" Text="{loc:T Dict_ColExample}"/>
                <TextBox Text="{Binding ExampleSentence}" CornerRadius="{DynamicResource Radius.Control}"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8" Margin="0,8,0,0">
                <Button Content="{loc:T SetEditor_Cancel}" Click="OnCancel" MinWidth="90" CornerRadius="{DynamicResource Radius.Control}"/>
                <Button Content="{loc:T SetEditor_Save}" Click="OnSave" MinWidth="90" Classes="accent" CornerRadius="{DynamicResource Radius.Control}"
                        IsEnabled="{Binding CanSave}"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
