<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Flippo.App.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:loc="using:Flippo.App.Localization"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
             x:Class="Flippo.App.Views.SessionSummaryView"
             x:DataType="vm:SessionSummaryViewModel"
             Focusable="True">

    <UserControl.KeyBindings>
        <KeyBinding Gesture="Enter" Command="{Binding DoneCommand}"/>
        <KeyBinding Gesture="R" Command="{Binding RepeatWrongCommand}"/>
    </UserControl.KeyBindings>

    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="20" MaxWidth="440">
        <TextBlock Classes="page-title" Text="{Binding Title}" HorizontalAlignment="Center"/>
        <TextBlock Classes="serif" Text="{Binding QuoteText}" FontSize="20" Opacity="0.85" HorizontalAlignment="Center" TextAlignment="Center"/>

        <StackPanel Orientation="Horizontal" Spacing="16" HorizontalAlignment="Center"
                    IsVisible="{Binding !NothingAnswered}">
            <Border Classes="metric-tile" MinWidth="120">
                <StackPanel Spacing="4" HorizontalAlignment="Center">
                    <TextBlock Classes="metric" Text="{Binding CorrectCount}" Foreground="{DynamicResource Brush.Success}" HorizontalAlignment="Center"/>
                    <TextBlock Classes="metric-label" Text="{loc:T Summary_Correct}" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
            <Border Classes="metric-tile" MinWidth="120">
                <StackPanel Spacing="4" HorizontalAlignment="Center">
                    <TextBlock Classes="metric" Text="{Binding WrongCount}" Foreground="{DynamicResource Brush.Danger}" HorizontalAlignment="Center"/>
                    <TextBlock Classes="metric-label" Text="{loc:T Summary_Wrong}" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
        </StackPanel>

        <StackPanel Orientation="Horizontal" Spacing="12" HorizontalAlignment="Center" Margin="0,8,0,0">
            <Button IsVisible="{Binding HasWrong}" Command="{Binding RepeatWrongCommand}" Classes="accent" Padding="20,10">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <PathIcon Data="{DynamicResource Icon.refresh}" Width="18" Height="18" Foreground="{DynamicResource Brush.OnAccent}"/>
                    <TextBlock Text="{loc:T Summary_RepeatWrong}" Foreground="{DynamicResource Brush.OnAccent}"/>
                </StackPanel>
            </Button>
            <Button Command="{Binding DoneCommand}" Padding="20,10">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <PathIcon Classes="icon" Data="{DynamicResource Icon.check}" Width="18" Height="18"/>
                    <TextBlock Text="{loc:T Summary_Done}"/>
                </StackPanel>
            </Button>
        </StackPanel>
    </StackPanel>
</UserControl>
