<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        x:Class="Flippo.App.Views.MessageWindow"
        Width="420" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        CanResize="False">
    <StackPanel Margin="24" Spacing="16">
        <TextBlock x:Name="TitleText" FontSize="18" FontWeight="SemiBold"/>
        <TextBlock x:Name="MessageText" TextWrapping="Wrap" Opacity="0.85"/>
        <Button Content="OK" Click="OnOk" HorizontalAlignment="Right" MinWidth="90" Classes="accent"/>
    </StackPanel>
</Window>
