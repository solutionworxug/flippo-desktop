<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="using:Flippo.App.Localization"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        x:Class="Flippo.App.Views.MessageWindow"
        Width="420" SizeToContent="Height"
        Background="{DynamicResource Brush.Bg.App}"
        WindowStartupLocation="CenterOwner"
        CanResize="False">
    <Border Classes="app-card" Margin="16">
        <StackPanel Spacing="16">
            <TextBlock x:Name="TitleText" Classes="section"/>
            <TextBlock x:Name="MessageText" Classes="body" TextWrapping="Wrap"/>
            <Button Content="{loc:T Message_OK}" Click="OnOk" HorizontalAlignment="Right" MinWidth="90" Classes="accent" CornerRadius="{DynamicResource Radius.Control}"/>
        </StackPanel>
    </Border>
</Window>
