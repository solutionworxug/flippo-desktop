<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Flippo.App.ViewModels"
        xmlns:loc="using:Flippo.App.Localization"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        x:Class="Flippo.App.Views.ImportPreviewWindow"
        x:DataType="vm:ImportPreviewViewModel"
        Title="Backup importieren"
        Width="460" SizeToContent="Height"
        Background="{DynamicResource Brush.Bg.App}"
        WindowStartupLocation="CenterOwner"
        CanResize="False">

    <Border Classes="app-card" Margin="16">
        <StackPanel Spacing="16">
            <TextBlock Classes="section" Text="{loc:T Import_Heading}"/>

            <Border Background="{DynamicResource Brush.Warning.Soft}" CornerRadius="{DynamicResource Radius.Control}" Padding="12">
                <StackPanel Spacing="4">
                    <TextBlock Classes="body" FontWeight="SemiBold" Text="{loc:T Import_ReplacesAllWarning}"/>
                    <TextBlock Classes="body" Text="{Binding Summary}"/>
                    <TextBlock Classes="caption" Text="{loc:T Import_AutoBackupHint}" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <CheckBox Content="{loc:T Import_ApplySettings}"
                      IsChecked="{Binding ApplySettings}"
                      IsVisible="{Binding HasSettings}"/>

            <Border IsVisible="{Binding HasWarnings}" Background="{DynamicResource Brush.Danger.Soft}" CornerRadius="{DynamicResource Radius.Control}" Padding="12">
                <StackPanel Spacing="4">
                    <TextBlock Classes="body" FontWeight="SemiBold" Text="{loc:T Import_WarningsHeader}"/>
                    <TextBlock Classes="caption" Text="{Binding WarningsText}" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
                <Button Content="{loc:T Import_Cancel}" Click="OnCancel" MinWidth="90" CornerRadius="{DynamicResource Radius.Control}"/>
                <Button Content="{loc:T Import_Import}" Click="OnConfirm" MinWidth="90" Classes="accent" CornerRadius="{DynamicResource Radius.Control}"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
