<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Flippo.App.ViewModels"
             xmlns:loc="using:Flippo.App.Localization"
             xmlns:domain="using:Flippo.Core.Domain"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="600"
             x:Class="Flippo.App.Views.UserDictionaryDetailView"
             x:DataType="vm:UserDictionaryDetailViewModel"
             x:Name="Root">

    <UserControl.Resources>
        <!-- DataGrid-Theme-Tokens lokal auf Brush.* umgelenkt (Fluent-DataGrid-Keys, siehe Avalonia.Controls.DataGrid/Themes/Fluent.xaml).
             Brush.Accent.Soft ist bereits eine teiltransparente Fläche, daher die Selection-Opacity-Keys auf 1 gesetzt
             (sonst würde die Fluent-Default-Opacity zusätzlich abdunkeln/aufhellen). -->
        <SolidColorBrush x:Key="DataGridColumnHeaderForegroundBrush" Color="{DynamicResource Color.Text.Secondary}"/>
        <SolidColorBrush x:Key="DataGridColumnHeaderBackgroundBrush" Color="{DynamicResource Color.Surface.Subtle}"/>
        <SolidColorBrush x:Key="DataGridColumnHeaderHoveredBackgroundBrush" Color="{DynamicResource Color.Surface.Subtle}"/>
        <SolidColorBrush x:Key="DataGridColumnHeaderPressedBackgroundBrush" Color="{DynamicResource Color.Surface.Subtle}"/>
        <SolidColorBrush x:Key="DataGridRowHoveredBackgroundColor" Color="{DynamicResource Color.Surface.Subtle}"/>
        <SolidColorBrush x:Key="DataGridRowSelectedBackgroundBrush" Color="{DynamicResource Color.Accent.Soft}"/>
        <SolidColorBrush x:Key="DataGridRowSelectedHoveredBackgroundBrush" Color="{DynamicResource Color.Accent.Soft}"/>
        <SolidColorBrush x:Key="DataGridRowSelectedUnfocusedBackgroundBrush" Color="{DynamicResource Color.Accent.Soft}"/>
        <SolidColorBrush x:Key="DataGridRowSelectedHoveredUnfocusedBackgroundBrush" Color="{DynamicResource Color.Accent.Soft}"/>
        <x:Double x:Key="DataGridRowSelectedBackgroundOpacity">1</x:Double>
        <x:Double x:Key="DataGridRowSelectedHoveredBackgroundOpacity">1</x:Double>
        <x:Double x:Key="DataGridRowSelectedUnfocusedBackgroundOpacity">1</x:Double>
        <x:Double x:Key="DataGridRowSelectedHoveredUnfocusedBackgroundOpacity">1</x:Double>
        <SolidColorBrush x:Key="DataGridGridLinesBrush" Color="{DynamicResource Color.Border.Subtle}"/>
        <SolidColorBrush x:Key="DataGridCellFocusVisualPrimaryBrush" Color="{DynamicResource Color.Accent}"/>
    </UserControl.Resources>

    <UserControl.Styles>
        <!-- Beispielsatz-Spalte liest editoriell -> Serif (CellStyleClasses setzt die Klasse auf die DataGridCell,
             darunter greift der Selector auf den generierten Zellinhalt). -->
        <Style Selector="DataGridCell.serif-cell TextBlock">
            <Setter Property="FontFamily" Value="{DynamicResource Font.Family.Serif}"/>
        </Style>
    </UserControl.Styles>

    <UserControl.KeyBindings>
        <KeyBinding Gesture="Escape" Command="{Binding BackCommand}"/>
    </UserControl.KeyBindings>

    <Grid RowDefinitions="Auto,*" Margin="24">
        <!-- Kopf -->
        <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto" Margin="0,0,0,16">
            <Button Grid.Column="0" Command="{Binding BackCommand}" Margin="0,0,12,0"
                    VerticalAlignment="Center" ToolTip.Tip="{loc:T Dict_Back}">
                <PathIcon Classes="icon" Data="{DynamicResource Icon.back}"/>
            </Button>
            <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                <TextBlock Classes="page-title" Text="{Binding Title}"/>
                <TextBlock Classes="caption" Text="{Binding ResultCount}"/>
            </StackPanel>
            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <TextBox Width="220" PlaceholderText="{loc:T Dict_SearchPlaceholder}" Text="{Binding SearchText}"/>
                <Button Content="{loc:T Dict_NewEntry}" Command="{Binding AddEntryCommand}" Classes="accent"/>
            </StackPanel>
        </Grid>

        <!-- Treffer -->
        <Panel Grid.Row="1">
            <Border CornerRadius="{DynamicResource Radius.Card}" ClipToBounds="True"
                    Background="{DynamicResource Brush.Surface.Card}" BoxShadow="{DynamicResource Shadow.Card}">
                <DataGrid ItemsSource="{Binding Results}"
                          SelectedItem="{Binding SelectedEntry}"
                          IsReadOnly="True" GridLinesVisibility="Horizontal"
                          CanUserResizeColumns="True" CanUserSortColumns="True"
                          RowHeight="40" ColumnHeaderHeight="40"
                          Background="{DynamicResource Brush.Surface.Card}"
                          Foreground="{DynamicResource Brush.Text.Primary}"
                          RowBackground="Transparent"
                          DoubleTapped="OnRowDoubleTapped">
                    <DataGrid.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="{loc:T Ctx_Edit}" Command="{Binding EditEntryCommand}"/>
                            <Separator/>
                            <MenuItem Header="{loc:T Ctx_Delete}" Command="{Binding DeleteEntryCommand}"/>
                        </ContextMenu>
                    </DataGrid.ContextMenu>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="{loc:T Dict_ColSource}" Binding="{Binding SourceWord}" Width="*"/>
                        <DataGridTextColumn Header="{loc:T Dict_ColTarget}" Binding="{Binding TargetWord}" Width="*"/>
                        <DataGridTextColumn Header="{loc:T Dict_ColPos}" Binding="{Binding PartOfSpeech}" Width="110"/>
                        <DataGridTextColumn Header="{loc:T Dict_ColExample}" Binding="{Binding ExampleSentence}" Width="2*"
                                             CellStyleClasses="serif-cell"/>
                        <DataGridTemplateColumn Header="" Width="Auto">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate x:DataType="domain:UserDictionaryEntry">
                                    <Button Content="{loc:T Dict_ToCard}" Margin="6,2"
                                            Command="{Binding #Root.((vm:UserDictionaryDetailViewModel)DataContext).AddToSetCommand}"
                                            CommandParameter="{Binding}"
                                            ToolTip.Tip="{loc:T Dict_ToCardTooltip}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <!-- Leerzustand -->
            <StackPanel IsVisible="{Binding IsEmpty}" VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="8">
                <TextBlock Classes="section" Text="{loc:T Dict_NoResults}" Opacity="0.6" HorizontalAlignment="Center"/>
            </StackPanel>
        </Panel>
    </Grid>
</UserControl>
