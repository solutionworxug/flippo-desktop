<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Flippo.App.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        x:Class="Flippo.App.Views.SetEditorWindow"
        x:DataType="vm:SetEditorViewModel"
        Title="Kartei"
        Width="440" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        CanResize="False">
    <StackPanel Margin="24" Spacing="12">
        <TextBlock Text="{Binding HeaderText}" FontSize="20" FontWeight="SemiBold"/>

        <StackPanel Spacing="4">
            <TextBlock Text="Titel" FontSize="12" Opacity="0.7"/>
            <TextBox Text="{Binding Title}" PlaceholderText="z.B. Spanisch A1"/>
        </StackPanel>
        <StackPanel Spacing="4">
            <TextBlock Text="Beschreibung" FontSize="12" Opacity="0.7"/>
            <TextBox Text="{Binding Description}"/>
        </StackPanel>
        <Grid ColumnDefinitions="*,12,*">
            <StackPanel Grid.Column="0" Spacing="4">
                <TextBlock Text="Quellsprache" FontSize="12" Opacity="0.7"/>
                <TextBox Text="{Binding SourceLanguage}" PlaceholderText="de"/>
            </StackPanel>
            <StackPanel Grid.Column="2" Spacing="4">
                <TextBlock Text="Zielsprache" FontSize="12" Opacity="0.7"/>
                <TextBox Text="{Binding TargetLanguage}" PlaceholderText="es"/>
            </StackPanel>
        </Grid>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8" Margin="0,8,0,0">
            <Button Content="Abbrechen" Click="OnCancel" MinWidth="90"/>
            <Button Content="Speichern" Click="OnSave" MinWidth="90" Classes="accent"
                    IsEnabled="{Binding CanSave}"/>
        </StackPanel>
    </StackPanel>
</Window>
