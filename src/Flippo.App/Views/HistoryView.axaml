<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Flippo.App.ViewModels"
             xmlns:loc="using:Flippo.App.Localization"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="860" d:DesignHeight="640"
             x:Class="Flippo.App.Views.HistoryView"
             x:DataType="vm:HistoryViewModel">

    <UserControl.KeyBindings>
        <KeyBinding Gesture="Escape" Command="{Binding BackCommand}"/>
    </UserControl.KeyBindings>

    <Grid RowDefinitions="Auto,*" Margin="24">
        <!-- Kopf -->
        <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,16">
            <StackPanel Grid.Column="0" Spacing="2">
                <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                    <PathIcon Classes="icon" Data="{DynamicResource Icon.history}"/>
                    <TextBlock Classes="page-title" Text="{loc:T Nav_History}"/>
                </StackPanel>
                <TextBlock Classes="caption" Text="{loc:T History_Subtitle}"/>
            </StackPanel>
            <Button Grid.Column="1" Command="{Binding LoadCommand}" VerticalAlignment="Top"
                    ToolTip.Tip="{loc:T Sets_Refresh}">
                <PathIcon Classes="icon" Data="{DynamicResource Icon.refresh}"/>
            </Button>
        </Grid>

        <ScrollViewer Grid.Row="1">
            <Panel>
                <ItemsControl ItemsSource="{Binding Rows}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:HistoryRow">
                            <Border Classes="app-card" Padding="16" Margin="0,0,0,10">
                                <Grid ColumnDefinitions="*,Auto,Auto">
                                    <!-- Set + Modus + Datum -->
                                    <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
                                        <TextBlock Classes="body" Text="{Binding SetName}" FontWeight="SemiBold" FontSize="16"/>
                                        <TextBlock Classes="caption">
                                            <Run Text="{Binding ModeDisplay}"/><Run Text="  ·  "/><Run Text="{Binding DateText}"/>
                                        </TextBlock>
                                    </StackPanel>

                                    <!-- Quote + Dauer -->
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center"
                                                Margin="16,0" MinWidth="150">
                                        <PathIcon Data="{DynamicResource Icon.check}" Width="16" Height="16"
                                                  Foreground="{DynamicResource Brush.Text.Secondary}"/>
                                        <StackPanel Spacing="2">
                                            <TextBlock Classes="body" Text="{Binding QuoteText}" FontWeight="SemiBold"/>
                                            <TextBlock Classes="caption" Text="{Binding DurationText}"/>
                                        </StackPanel>
                                    </StackPanel>

                                    <!-- Aktionen -->
                                    <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                        <Button Content="{loc:T History_RepeatWrong}"
                                                IsEnabled="{Binding HasWrong}"
                                                Command="{Binding $parent[ItemsControl].((vm:HistoryViewModel)DataContext).RepeatWrongCommand}"
                                                CommandParameter="{Binding}"
                                                ToolTip.Tip="{loc:T History_RepeatWrongTooltip}"/>
                                        <Button Content="{loc:T History_Relearn}"
                                                IsEnabled="{Binding CanRelearn}"
                                                Command="{Binding $parent[ItemsControl].((vm:HistoryViewModel)DataContext).RelearnSetCommand}"
                                                CommandParameter="{Binding}"
                                                ToolTip.Tip="{loc:T History_RelearnTooltip}"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Leerzustand -->
                <StackPanel IsVisible="{Binding IsEmpty}" VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="8" Margin="0,60">
                    <TextBlock Classes="section" Text="{loc:T History_EmptyTitle}" Opacity="0.7" HorizontalAlignment="Center"/>
                    <TextBlock Classes="body" Text="{loc:T History_EmptyHint}" Opacity="0.5" HorizontalAlignment="Center"/>
                </StackPanel>
            </Panel>
        </ScrollViewer>
    </Grid>
</UserControl>
