<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Flippo.App.ViewModels"
        xmlns:loc="using:Flippo.App.Localization"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1000" d:DesignHeight="680"
        x:Class="Flippo.App.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Width="1000" Height="680" MinWidth="720" MinHeight="480"
        Title="{Binding Title}">

    <LayoutTransformControl>
        <LayoutTransformControl.LayoutTransform>
            <ScaleTransform ScaleX="{Binding UiScale}" ScaleY="{Binding UiScale}"/>
        </LayoutTransformControl.LayoutTransform>
    <Grid ColumnDefinitions="200,*">
        <!-- Sidebar -->
        <Border Grid.Column="0" Background="{DynamicResource SystemControlBackgroundListLowBrush}" Padding="14">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="FLIPPO" FontSize="24" FontWeight="Bold" Margin="4,2,4,4"/>
                <TextBlock DockPanel.Dock="Top" Text="{loc:T App_Subtitle}" FontSize="12" Opacity="0.6" Margin="4,0,4,18"/>

                <Button DockPanel.Dock="Top" Content="{loc:T Nav_Back}"
                        Command="{Binding GoBackCommand}"
                        IsVisible="{Binding CanGoBack}"
                        HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                        Margin="0,0,0,12"/>

                <Button DockPanel.Dock="Top" Content="{loc:T Nav_Sets}"
                        Command="{Binding ShowSetsCommand}"
                        HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                        Margin="0,0,0,6"/>
                <Button DockPanel.Dock="Top" Content="{loc:T Nav_Settings}"
                        Command="{Binding ShowSettingsCommand}"
                        HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"/>

                <TextBlock DockPanel.Dock="Bottom" Text="v0.1.0-dev" FontSize="11" Opacity="0.5"/>
                <Panel/>
            </DockPanel>
        </Border>

        <!-- Seiteninhalt (ViewLocator löst CurrentPage-VM → View auf) -->
        <ContentControl Grid.Column="1" Content="{Binding CurrentPage}"/>
    </Grid>
    </LayoutTransformControl>
</Window>
