<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Flippo.App.ViewModels"
        xmlns:loc="using:Flippo.App.Localization"
        xmlns:conv="using:Flippo.App.Converters"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1000" d:DesignHeight="680"
        x:Class="Flippo.App.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Width="1000" Height="680" MinWidth="720" MinHeight="480"
        Background="{DynamicResource Brush.Bg.App}"
        Title="{Binding Title}">

    <!-- Globale Kürzel: einzige autoritative Ausführung (Menü zeigt sie nur via Gesture an). -->
    <Window.KeyBindings>
        <KeyBinding Gesture="Ctrl+Shift+N" Command="{Binding NewSetCommand}"/>
        <KeyBinding Gesture="Ctrl+I" Command="{Binding ImportFileCommand}"/>
        <KeyBinding Gesture="Ctrl+Shift+I" Command="{Binding ImportBackupCommand}"/>
        <KeyBinding Gesture="Ctrl+E" Command="{Binding ExportBackupCommand}"/>
        <KeyBinding Gesture="Ctrl+Q" Command="{Binding QuitCommand}"/>
        <KeyBinding Gesture="F5" Command="{Binding RefreshCommand}"/>
        <KeyBinding Gesture="Ctrl+L" Command="{Binding LearnAllDueCommand}" CommandParameter="Flashcard"/>
        <KeyBinding Gesture="Alt+Left" Command="{Binding GoBackCommand}"/>
    </Window.KeyBindings>

    <!-- Ein Menümodell, plattformadaptiv: macOS exportiert nativ, Windows/Linux zeigen die NativeMenuBar. -->
    <NativeMenu.Menu>
        <NativeMenu>
            <NativeMenuItem Header="{loc:T Menu_File}">
                <NativeMenuItem.Menu>
                    <NativeMenu>
                        <NativeMenuItem Header="{loc:T Menu_NewSet}" Command="{Binding NewSetCommand}" Gesture="Ctrl+Shift+N"/>
                        <NativeMenuItem Header="{loc:T Menu_ImportThemeSet}" Command="{Binding ImportThemeSetCommand}"/>
                        <NativeMenuItemSeparator/>
                        <NativeMenuItem Header="{loc:T Menu_ImportFile}" Command="{Binding ImportFileCommand}" Gesture="Ctrl+I"/>
                        <NativeMenuItem Header="{loc:T Menu_ImportBackup}" Command="{Binding ImportBackupCommand}" Gesture="Ctrl+Shift+I"/>
                        <NativeMenuItem Header="{loc:T Menu_ExportBackup}" Command="{Binding ExportBackupCommand}" Gesture="Ctrl+E"/>
                        <NativeMenuItemSeparator/>
                        <NativeMenuItem Header="{loc:T Menu_Quit}" Command="{Binding QuitCommand}" Gesture="Ctrl+Q"/>
                    </NativeMenu>
                </NativeMenuItem.Menu>
            </NativeMenuItem>

            <NativeMenuItem Header="{loc:T Menu_View}">
                <NativeMenuItem.Menu>
                    <NativeMenu>
                        <NativeMenuItem Header="{loc:T Nav_Dashboard}" Command="{Binding ShowDashboardCommand}"/>
                        <NativeMenuItem Header="{loc:T Nav_Sets}" Command="{Binding ShowSetsCommand}"/>
                        <NativeMenuItem Header="{loc:T Nav_Dictionary}" Command="{Binding ShowDictionariesCommand}"/>
                        <NativeMenuItem Header="{loc:T Nav_Statistics}" Command="{Binding ShowStatisticsCommand}"/>
                        <NativeMenuItem Header="{loc:T Nav_History}" Command="{Binding ShowHistoryCommand}"/>
                        <NativeMenuItem Header="{loc:T Nav_Settings}" Command="{Binding ShowSettingsCommand}"/>
                        <NativeMenuItemSeparator/>
                        <NativeMenuItem Header="{loc:T Nav_Back}" Command="{Binding GoBackCommand}" Gesture="Alt+Left"/>
                        <NativeMenuItem Header="{loc:T Menu_Refresh}" Command="{Binding RefreshCommand}" Gesture="F5"/>
                    </NativeMenu>
                </NativeMenuItem.Menu>
            </NativeMenuItem>

            <NativeMenuItem Header="{loc:T Menu_Learn}">
                <NativeMenuItem.Menu>
                    <NativeMenu>
                        <NativeMenuItem Header="{loc:T Sets_ModeFlashcard}" Command="{Binding LearnAllDueCommand}" CommandParameter="Flashcard" Gesture="Ctrl+L"/>
                        <NativeMenuItem Header="{loc:T Sets_ModeFreeText}" Command="{Binding LearnAllDueCommand}" CommandParameter="FreeText"/>
                        <NativeMenuItem Header="{loc:T Sets_ModeMultipleChoice}" Command="{Binding LearnAllDueCommand}" CommandParameter="MultipleChoice"/>
                    </NativeMenu>
                </NativeMenuItem.Menu>
            </NativeMenuItem>

            <NativeMenuItem Header="{loc:T Menu_Help}">
                <NativeMenuItem.Menu>
                    <NativeMenu>
                        <NativeMenuItem Header="{loc:T Menu_Shortcuts}" Command="{Binding ShortcutsCommand}"/>
                        <NativeMenuItemSeparator/>
                        <NativeMenuItem Header="{loc:T Menu_GitHub}" Command="{Binding OpenGitHubCommand}"/>
                        <NativeMenuItem Header="{loc:T Menu_CheckUpdates}" Command="{Binding CheckUpdatesCommand}"/>
                        <NativeMenuItemSeparator/>
                        <NativeMenuItem Header="{loc:T Menu_About}" Command="{Binding AboutCommand}"/>
                    </NativeMenu>
                </NativeMenuItem.Menu>
            </NativeMenuItem>
        </NativeMenu>
    </NativeMenu.Menu>

    <DockPanel>
        <!-- In-Window-Menüleiste (Windows/Linux); versteckt sich, wenn macOS nativ exportiert. Nicht mitskaliert. -->
        <NativeMenuBar DockPanel.Dock="Top"/>

        <LayoutTransformControl>
            <LayoutTransformControl.LayoutTransform>
                <ScaleTransform ScaleX="{Binding UiScale}" ScaleY="{Binding UiScale}"/>
            </LayoutTransformControl.LayoutTransform>
            <Grid ColumnDefinitions="212,*">
                <!-- Sidebar -->
                <Border Grid.Column="0" Background="{DynamicResource Brush.Surface.Card}"
                        BorderBrush="{DynamicResource Brush.Border.Subtle}" BorderThickness="0,0,1,0" Padding="16">
                    <DockPanel>
                        <StackPanel DockPanel.Dock="Top" Margin="4,2,4,20" Spacing="2">
                            <TextBlock Text="FLIPPO" Classes="display" FontSize="26"/>
                            <TextBlock Classes="eyebrow" Text="{loc:T App_Subtitle}"/>
                        </StackPanel>

                        <Button DockPanel.Dock="Top" Classes="nav" Content="{loc:T Nav_Back}"
                                Command="{Binding GoBackCommand}"
                                IsVisible="{Binding CanGoBack}"
                                Margin="0,0,0,12"/>

                        <Button DockPanel.Dock="Top" Classes="nav" Command="{Binding ShowDashboardCommand}" Margin="0,0,0,4"
                                Classes.nav-active="{Binding ActiveNav, Converter={x:Static conv:StringEqualsConverter.Instance}, ConverterParameter=Dashboard}">
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <PathIcon Classes="icon" Data="{DynamicResource Icon.dashboard}"/>
                                <TextBlock Text="{loc:T Nav_Dashboard}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button DockPanel.Dock="Top" Classes="nav" Command="{Binding ShowSetsCommand}" Margin="0,0,0,4"
                                Classes.nav-active="{Binding ActiveNav, Converter={x:Static conv:StringEqualsConverter.Instance}, ConverterParameter=Sets}">
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <PathIcon Classes="icon" Data="{DynamicResource Icon.decks}"/>
                                <TextBlock Text="{loc:T Nav_Sets}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button DockPanel.Dock="Top" Classes="nav" Command="{Binding ShowDictionariesCommand}" Margin="0,0,0,4"
                                Classes.nav-active="{Binding ActiveNav, Converter={x:Static conv:StringEqualsConverter.Instance}, ConverterParameter=Dictionary}">
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <PathIcon Classes="icon" Data="{DynamicResource Icon.dictionary}"/>
                                <TextBlock Text="{loc:T Nav_Dictionary}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button DockPanel.Dock="Top" Classes="nav" Command="{Binding ShowStatisticsCommand}" Margin="0,0,0,4"
                                Classes.nav-active="{Binding ActiveNav, Converter={x:Static conv:StringEqualsConverter.Instance}, ConverterParameter=Statistics}">
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <PathIcon Classes="icon" Data="{DynamicResource Icon.statistics}"/>
                                <TextBlock Text="{loc:T Nav_Statistics}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button DockPanel.Dock="Top" Classes="nav" Command="{Binding ShowHistoryCommand}" Margin="0,0,0,4"
                                Classes.nav-active="{Binding ActiveNav, Converter={x:Static conv:StringEqualsConverter.Instance}, ConverterParameter=History}">
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <PathIcon Classes="icon" Data="{DynamicResource Icon.history}"/>
                                <TextBlock Text="{loc:T Nav_History}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button DockPanel.Dock="Top" Classes="nav" Command="{Binding ShowSettingsCommand}"
                                Classes.nav-active="{Binding ActiveNav, Converter={x:Static conv:StringEqualsConverter.Instance}, ConverterParameter=Settings}">
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <PathIcon Classes="icon" Data="{DynamicResource Icon.settings}"/>
                                <TextBlock Text="{loc:T Nav_Settings}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <TextBlock DockPanel.Dock="Bottom" Classes="caption" Text="{Binding AppVersion}" Opacity="0.7"/>

                        <Border DockPanel.Dock="Bottom" Classes="sidebar-cta" Margin="0,12,0,12">
                            <Button Background="Transparent" Padding="0" HorizontalAlignment="Stretch"
                                    Command="{Binding LearnAllDueCommand}" CommandParameter="Flashcard">
                                <StackPanel Spacing="6">
                                    <PathIcon Data="{DynamicResource Icon.play}" Width="22" Height="22" Foreground="{DynamicResource Brush.OnAccent}"/>
                                    <TextBlock Text="{loc:T Nav_LearnNow}" Foreground="{DynamicResource Brush.OnAccent}" FontWeight="SemiBold"/>
                                </StackPanel>
                            </Button>
                        </Border>

                        <Panel/>
                    </DockPanel>
                </Border>

                <!-- Seiteninhalt (ViewLocator löst CurrentPage-VM → View auf) -->
                <DockPanel Grid.Column="1">
                    <!-- Update-Banner: nur sichtbar, wenn ein Update heruntergeladen wurde (nicht-blockierend) -->
                    <Border DockPanel.Dock="Top" IsVisible="{Binding UpdateReady}"
                            Background="{DynamicResource Brush.Accent}" Padding="16,10">
                        <StackPanel Orientation="Horizontal" Spacing="14" HorizontalAlignment="Center">
                            <TextBlock Text="{loc:T Update_Available}" VerticalAlignment="Center" Foreground="White"/>
                            <Button Content="{loc:T Update_Restart}" Command="{Binding ApplyUpdateCommand}"/>
                        </StackPanel>
                    </Border>
                    <ContentControl Content="{Binding CurrentPage}"/>
                </DockPanel>
            </Grid>
        </LayoutTransformControl>
    </DockPanel>
</Window>
