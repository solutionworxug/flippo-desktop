<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Flippo.App.ViewModels"
             xmlns:loc="using:Flippo.App.Localization"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="820" d:DesignHeight="720"
             x:Class="Flippo.App.Views.DashboardView"
             x:DataType="vm:DashboardViewModel">

    <ScrollViewer>
        <StackPanel Spacing="20" Margin="24">

            <!-- Kopf: Begrüßung + Streak -->
            <Grid ColumnDefinitions="*,Auto">
                <TextBlock Grid.Column="0" Classes="display" Text="{Binding Greeting}" VerticalAlignment="Center"/>
                <Border Grid.Column="1" Classes="streak-pill" IsVisible="{Binding HasStreak}" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <PathIcon Classes="icon" Data="{DynamicResource Icon.streak}" Width="16" Height="16" Foreground="{DynamicResource Brush.Tertiary}"/>
                        <TextBlock Text="{Binding StreakText}" FontWeight="SemiBold" Foreground="{DynamicResource Brush.Tertiary}"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Empty-State: keine Karteien -->
            <Border Classes="app-card" IsVisible="{Binding !HasSets}">
                <StackPanel Spacing="10" HorizontalAlignment="Center" Margin="0,20">
                    <TextBlock Classes="section" Text="{loc:T Dash_EmptyTitle}" HorizontalAlignment="Center"/>
                    <TextBlock Classes="caption" Text="{loc:T Dash_EmptyHint}" HorizontalAlignment="Center"/>
                    <Button Content="{loc:T Dash_CreateSet}" Command="{Binding NewSetCommand}" Classes="accent" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>

            <!-- CTA / Alles-erledigt (nur mit Karteien) -->
            <Panel IsVisible="{Binding HasSets}">
                <!-- Jetzt lernen (Hero) -->
                <Border Classes="hero-card" IsVisible="{Binding HasDue}" Background="{DynamicResource Brush.Accent}">
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Grid.Column="0" Spacing="4" VerticalAlignment="Center">
                            <TextBlock Classes="eyebrow" Text="{loc:T Dash_LearnNow}" Foreground="White" Opacity="0.85"/>
                            <TextBlock Classes="metric-lg" Text="{Binding DueTotal}" Foreground="White"/>
                            <TextBlock Classes="body" Text="{Binding DueCountText}" Foreground="White" Opacity="0.9"/>
                        </StackPanel>
                        <Button Grid.Column="1" Command="{Binding LearnAllDueCommand}"
                                Background="White" Foreground="{DynamicResource Brush.Accent}"
                                CornerRadius="{DynamicResource Radius.Control}"
                                VerticalAlignment="Center" MinWidth="140" Padding="18,12">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <PathIcon Data="{DynamicResource Icon.play}" Width="18" Height="18" Foreground="{DynamicResource Brush.Accent}"/>
                                <TextBlock Text="{loc:T Dash_LearnNow}" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Button>
                    </Grid>
                </Border>
                <!-- Alles erledigt -->
                <Border Classes="hero-card" IsVisible="{Binding !HasDue}">
                    <StackPanel Spacing="6">
                        <PathIcon Data="{DynamicResource Icon.check}" Width="28" Height="28" Foreground="{DynamicResource Brush.Success}"/>
                        <TextBlock Classes="section" Text="{loc:T Dash_AllDone}"/>
                        <TextBlock Classes="caption" Text="{loc:T Dash_AllDoneHint}"/>
                    </StackPanel>
                </Border>
            </Panel>

            <!-- Kennzahl-Kacheln -->
            <Grid ColumnDefinitions="*,*,*" IsVisible="{Binding HasSets}">
                <Border Grid.Column="0" Classes="metric-tile" Margin="0,0,8,0">
                    <StackPanel HorizontalAlignment="Center" Spacing="8">
                        <TextBlock Classes="metric" Text="{Binding DueToday}" Foreground="{DynamicResource Brush.Warning}" HorizontalAlignment="Center"/>
                        <TextBlock Classes="metric-label" Text="{loc:T Sets_Due}" HorizontalAlignment="Center"/>
                        <Border Height="4" CornerRadius="{DynamicResource Radius.Bar}" Background="{DynamicResource Brush.Surface.Subtle}" HorizontalAlignment="Stretch">
                            <Border Height="4" CornerRadius="{DynamicResource Radius.Bar}" Background="{DynamicResource Brush.Warning}" HorizontalAlignment="Left" Width="40"/>
                        </Border>
                    </StackPanel>
                </Border>
                <Border Grid.Column="1" Classes="metric-tile" Margin="0,0,8,0">
                    <StackPanel HorizontalAlignment="Center" Spacing="8">
                        <TextBlock Classes="metric" Text="{Binding NewCards}" Foreground="{DynamicResource Brush.Success}" HorizontalAlignment="Center"/>
                        <TextBlock Classes="metric-label" Text="{loc:T Sets_New}" HorizontalAlignment="Center"/>
                        <Border Height="4" CornerRadius="{DynamicResource Radius.Bar}" Background="{DynamicResource Brush.Surface.Subtle}" HorizontalAlignment="Stretch">
                            <Border Height="4" CornerRadius="{DynamicResource Radius.Bar}" Background="{DynamicResource Brush.Success}" HorizontalAlignment="Left" Width="40"/>
                        </Border>
                    </StackPanel>
                </Border>
                <Border Grid.Column="2" Classes="metric-tile">
                    <StackPanel HorizontalAlignment="Center" Spacing="8">
                        <TextBlock Classes="metric" Text="{Binding LeechCards}" Foreground="{DynamicResource Brush.Danger}" HorizontalAlignment="Center"/>
                        <TextBlock Classes="metric-label" Text="{loc:T Stats_Leeches}" HorizontalAlignment="Center"/>
                        <Border Height="4" CornerRadius="{DynamicResource Radius.Bar}" Background="{DynamicResource Brush.Surface.Subtle}" HorizontalAlignment="Stretch">
                            <Border Height="4" CornerRadius="{DynamicResource Radius.Bar}" Background="{DynamicResource Brush.Danger}" HorizontalAlignment="Left" Width="40"/>
                        </Border>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Letzte Session -->
            <Border Classes="app-card" IsVisible="{Binding HasLastSession}">
                <StackPanel Spacing="6">
                    <TextBlock Classes="eyebrow" Text="{loc:T Dash_LastSession}"/>
                    <TextBlock Classes="body" Text="{Binding LastSessionText}"/>
                </StackPanel>
            </Border>

            <!-- Schnellzugriff -->
            <StackPanel Spacing="10" IsVisible="{Binding HasSets}">
                <TextBlock Classes="section" Text="{loc:T Dash_QuickActions}"/>
                <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto">
                    <Border Grid.Row="0" Grid.Column="0" Classes="quick-action" Margin="0,0,6,6">
                        <Button Command="{Binding GoSetsCommand}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Background="Transparent" BorderThickness="0">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <PathIcon Classes="icon" Data="{DynamicResource Icon.decks}"/>
                                <TextBlock Classes="body" Text="{loc:T Nav_Sets}"/>
                            </StackPanel>
                        </Button>
                    </Border>
                    <Border Grid.Row="0" Grid.Column="1" Classes="quick-action" Margin="6,0,0,6">
                        <Button Command="{Binding NewSetCommand}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Background="Transparent" BorderThickness="0">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <PathIcon Classes="icon" Data="{DynamicResource Icon.folder-add}"/>
                                <TextBlock Classes="body" Text="{loc:T Dash_CreateSet}"/>
                            </StackPanel>
                        </Button>
                    </Border>
                    <Border Grid.Row="1" Grid.Column="0" Classes="quick-action" Margin="0,0,6,0">
                        <Button Command="{Binding GoStatisticsCommand}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Background="Transparent" BorderThickness="0">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <PathIcon Classes="icon" Data="{DynamicResource Icon.statistics}"/>
                                <TextBlock Classes="body" Text="{loc:T Nav_Statistics}"/>
                            </StackPanel>
                        </Button>
                    </Border>
                    <Border Grid.Row="1" Grid.Column="1" Classes="quick-action" Margin="6,0,0,0">
                        <Button Command="{Binding LearnAllDueCommand}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Background="Transparent" BorderThickness="0">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <PathIcon Classes="icon" Data="{DynamicResource Icon.play}"/>
                                <TextBlock Classes="body" Text="{loc:T Dash_ActionLearn}"/>
                            </StackPanel>
                        </Button>
                    </Border>
                </Grid>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</UserControl>
